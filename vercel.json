{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" },
    {
      "source": "/api/:path*",
      "destination": "https://yazan-api-portfolio.vercel.app/api/:path*" 
    }
  ]
}
